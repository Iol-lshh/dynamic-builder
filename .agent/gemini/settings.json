{
  "autoDreamEnabled": true,
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "MultiEdit",
      "Bash",
      "NotebookEdit",
      "Bash(bash ~/.gemini/extensions/dynamic-builder/skills/build/scripts/build-dynamic.sh*)",
      "Bash(bash ~/.gemini/extensions/dynamic-builder/skills/clean/scripts/clean-dynamic.sh*)",
      "Bash(bash ~/.gemini/extensions/dynamic-builder/skills/clean-worktree/scripts/clean-worktree.sh*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/protect-branch-file.sh",
            "statusMessage": "워크트리 확인 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "~/.gemini/hooks/protect-branch-git.sh",
            "statusMessage": "워크트리 확인 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/protect-worktree-bash.sh",
            "statusMessage": "워크트리 경로 확인 중..."
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/workflow-meta-creator.sh",
            "statusMessage": "워크플로우 메타 파일 생성 중..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/workflow-details-read-tracker.sh",
            "statusMessage": "워크플로우 details 읽기 추적 중..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/workflow-details-enforcer.sh",
            "statusMessage": "워크플로우 details 읽기 검증 중..."
          }
        ]
      }
    ]
  }
}
