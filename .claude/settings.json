{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "MultiEdit",
      "Bash",
      "NotebookEdit"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-branch-file.sh",
            "statusMessage": "워크트리 확인 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git:*)",
            "command": "~/.claude/hooks/protect-branch-git.sh",
            "statusMessage": "워크트리 확인 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-worktree-bash.sh",
            "statusMessage": "워크트리 경로 확인 중..."
          }
        ]
      }
    ]
  }
}
