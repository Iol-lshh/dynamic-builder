{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-branch-file.sh",
            "statusMessage": "보호 브랜치 확인 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git:*)",
            "command": "~/.claude/hooks/protect-branch-git.sh",
            "statusMessage": "보호 브랜치 확인 중..."
          }
        ]
      }
    ]
  }
}
